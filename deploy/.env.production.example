MYSQL_IMAGE=mysql:8.0
MYSQL_DATABASE=payment_router
MYSQL_USER=payment_router
MYSQL_PASSWORD=replace-with-strong-mysql-user-password
MYSQL_ROOT_PASSWORD=replace-with-strong-mysql-root-password
MYSQL_PORT=3306

REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password

NGINX_HTTP_PORT=80

SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/payment_router?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=payment_router
SPRING_DATASOURCE_PASSWORD=replace-with-strong-mysql-user-password
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=replace-with-strong-redis-password
SPRING_DATA_REDIS_DATABASE=0

PAY_ROUTER_ENFORCE_PRODUCTION_SECRETS=true
PAY_ROUTER_JWT_SECRET=replace-with-random-secret-at-least-32-characters
PAY_ROUTER_AES_KEY=replace-with-random-aes-key-at-least-16-characters
PAY_ROUTER_CHANNEL_ADAPTER=lfwin
PAY_ROUTER_LFWIN_BASE_URL=https://api2.lfwin.com
PAY_ROUTER_LFWIN_TIMEOUT_SECONDS=15
PAY_QUERY_ENABLED=true
PAY_QUERY_INTERVAL_SECONDS=30
PAY_QUERY_MAX_COUNT=10
PAY_ROUTER_LIMIT_RESERVATION_ENABLED=false
PAY_ROUTER_LIMIT_RESERVATION_CHECK_DELAY_SECONDS=300
PAY_ROUTER_LIMIT_RESERVATION_COMPENSATION_INTERVAL_SECONDS=60
PAY_ROUTER_LIMIT_RESERVATION_COMPENSATION_BATCH_SIZE=100
PAY_ROUTER_LEGACY_POOL_SIGN_ENABLED=true
PAY_ROUTER_LEGACY_POOL_SIGN_FALLBACK_AFTER_DEFAULT_APP_SECRET_FAILURE=true
PAY_ROUTER_LEGACY_POOL_SIGN_WARN_ONLY=true
PAY_ROUTER_LEGACY_POOL_SIGN_ALLOW_POOL_CODES=
PAY_ROUTER_LEGACY_POOL_SIGN_DENY_POOL_CODES=

BACKEND_LOG_PATH=/app/logs
